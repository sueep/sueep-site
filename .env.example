# Public site + APIs (existing)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Internal ERP (app.sueep.com)
# PostgreSQL — required for Prisma (use Neon, Supabase, or local Docker Postgres; not SQLite on Vercel).
# Example local: postgresql://postgres:postgres@localhost:5432/sueep_erp
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
ERP_SESSION_SECRET="min-32-chars-random-use-openssl-rand-hex-32"
ERP_ACCESS_PASSWORD="change-me-internal-only"
