# Public site + APIs (existing)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Internal ERP (app.sueep.com)
# Neon: use the *pooled* connection for DATABASE_URL (host contains "-pooler") and the *direct* for DIRECT_URL.
# Local Docker: use the same URL for both.
# Add &connect_timeout=15 if you see timeouts after idle (Neon scale-to-zero).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

ERP_SESSION_SECRET="min-32-chars-random-use-openssl-rand-hex-32"
ERP_ACCESS_PASSWORD="change-me-internal-only"

# HubSpot (private app — optional until CRM sync is used)
# HUBSPOT_ACCESS_TOKEN=   # Private app access token (outbound API)
# HUBSPOT_CLIENT_SECRET=  # Same app "Client secret" — required to verify inbound webhooks
#
# Pipeline + stage IDs — single-line JSON. Get IDs from HubSpot (deal pipeline/stage settings or sample deal API).
# Post-con + Janitorial → ERP COMMERCIAL; Residential → RESIDENTIAL.
# Commercial: quote approved = awarded; Residential: confirmed = awarded (same ERP treatment).
# HUBSPOT_PIPELINE_STAGE_MAP={"postConstruction":{"pipelineId":"","stages":{"quoteApproved":"","workInProgress":"","workCompleted":""}},"janitorial":{"pipelineId":"","stages":{"quoteApproved":"","workInProgress":"","workCompleted":""}},"residential":{"pipelineId":"","stages":{"confirmed":"","workInProgress":"","workCompleted":""}}}
